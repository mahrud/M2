use arithmetic;
use common;
use util;
use expr;

-----------------------------------------------------------------------------
-- C++ interface functions defined in std-thread.cpp
-----------------------------------------------------------------------------

import compute(str:string, n:int):void;
import initialize(live:bool):void;

threadLocal export myN := int(0);
setupvarThread("myN", toExpr(myN));

-----------------------------------------------------------------------------
-- Local utilities
-----------------------------------------------------------------------------

-----------------------------------------------------------------------------
-- Exported Functions
-----------------------------------------------------------------------------

myprint(e:Expr):Expr := (
    initialize(false);
    when e is text:stringCell do (
	myN = myN + 1;
	compute(text.v, myN);
	toExpr(myN))
    else WrongArgString(1));
setupfun("myprint", myprint).Protected = false; -- will be overloaded
